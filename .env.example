# ─── Admin Auth ───────────────────────────────────────────────
# สร้าง JWT Secret ด้วย: openssl rand -base64 32
JWT_SECRET=your-random-secret-here

# Admin email addresses (ตรงกับใน lib/auth.ts แล้ว)
# supapol_111213@hotmail.com → ADMIN_HASH_1
# tansika.p1998@gmail.com   → ADMIN_HASH_2
# (leave blank → use Forgot Password flow to set password first time)
ADMIN_HASH_1=
ADMIN_HASH_2=

# ─── Email (Resend) ────────────────────────────────────────────
# Sign up free at https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# From address (ต้อง verify domain ใน Resend ก่อน)
# ใช้ "onboarding@resend.dev" สำหรับ test โดยไม่ต้อง verify
RESEND_FROM=PB3D Admin <noreply@pb3dprint.com>

# Base URL ของ site (ใช้สำหรับสร้าง reset link)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# ─── Vercel KV (Redis) ─────────────────────────────────────────
# Enable ใน Vercel Dashboard → Storage → Create KV Store
# แล้ว Vercel จะ inject ค่าเหล่านี้ให้อัตโนมัติ
KV_REST_API_URL=
KV_REST_API_TOKEN=
